@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

<!DOCTYPE html>
<html lang="en" data-bs-theme="@(ViewBag.Theme ?? "light")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @Localizer["InventoryManagement"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/inventory.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-box-seam"></i> @Localizer["InventoryManager"]
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house"></i> @Localizer["Home"]
                            </a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Inventory" asp-action="Create">
                                    <i class="bi bi-plus-circle"></i> @Localizer["NewInventory"]
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="User" asp-action="Profile">
                                    <i class="bi bi-person"></i> @Localizer["MyProfile"]
                                </a>
                            </li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                        <i class="bi bi-shield-lock"></i> @Localizer["Admin"]
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                    
                    <!-- Search Bar -->
                    <form class="d-flex mx-auto w-25" asp-controller="Search" asp-action="Index" method="get">
                        <input class="form-control me-2" type="search" name="q" placeholder="@Localizer["SearchPlaceholder"]" aria-label="@Localizer["Search"]">
                        <button class="btn btn-outline-light" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </form>

                    <!-- Theme and Language Switcher -->
                    <div class="d-flex align-items-center me-3">
                        <div class="btn-group me-2">
                            <button type="button" class="btn btn-sm btn-outline-light dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="bi bi-palette"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <button class="dropdown-item theme-switch" data-theme="light">
                                        <i class="bi bi-sun"></i> @Localizer["Light"]
                                    </button>
                                </li>
                                <li>
                                    <button class="dropdown-item theme-switch" data-theme="dark">
                                        <i class="bi bi-moon"></i> @Localizer["Dark"]
                                    </button>
                                </li>
                            </ul>
                        </div>

                        <div class="btn-group">
                            <button type="button" class="btn btn-sm btn-outline-light dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="bi bi-globe"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <button class="dropdown-item language-switch" data-lang="en">
                                        🇺🇸 @Localizer["English"]
                                    </button>
                                </li>
                                <li>
                                    <button class="dropdown-item language-switch" data-lang="es">
                                        🇪🇸 @Localizer["Spanish"]
                                    </button>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <!-- User Menu -->
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" asp-controller="User" asp-action="Profile">
                                            <i class="bi bi-person"></i> @Localizer["Profile"]
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Inventory" asp-action="MyInventories">
                                            <i class="bi bi-box"></i> @Localizer["MyInventories"]
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="User" asp-action="AccessibleInventories">
                                            <i class="bi bi-key"></i> @Localizer["SharedWithMe"]
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item">
                                                <i class="bi bi-box-arrow-right"></i> @Localizer["Logout"]
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right"></i> @Localizer["Login"]
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">
                                    <i class="bi bi-person-plus"></i> @Localizer["Register"]
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted">
        <div class="container text-center py-3">
            &copy; @DateTime.Now.Year - @Localizer["InventoryManagementSystem"]
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>